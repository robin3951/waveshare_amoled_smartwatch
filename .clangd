CompileFlags:
  Add:
    - -DCONFIG_XPOWERS_ESP_IDF_NEW_API=1
    # clangd (apt.llvm.org) has no Xtensa backend; query-driver returns
    # "xtensa-esp32s3-elf" which causes "Couldn't build compiler instance".
    # Force a known target so clangd can parse; Xtensa system-includes from
    # --query-driver still apply, giving correct ESP-IDF header resolution.
    - --target=x86_64-linux-gnu
  Remove:
    # Xtensa-specific machine flags — unknown to x86_64 clang
    - -mlongcalls
    - -mtext-section-literals
    - -mfix-esp32-psram-cache-issue
    - -mfix-esp32-psram-cache-strategy=*
    - -mdisable-hardware-atomics
    - -mno-target-align
    # GCC-only optimisation flags
    - -fno-shrink-wrap
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
    - -fno-jump-tables
    - -fno-exceptions
    - -fno-rtti
    # GCC-only warning flags — clang emits -Wunknown-warning-option for these,
    # which becomes a fatal error under -Werror=all and prevents AST creation.
    - -Wno-frame-address
    - -Wno-maybe-uninitialized
    - -Wno-old-style-declaration
    # GCC param syntax
    - --param=max-inline-insns-single=*

Diagnostics:
  Suppress:
    - pp_file_not_found
    - drv_unknown_argument
    - drv_unknown_argument_with_suggestion

# Requires clangd 22+ (Documentation/CommentFormat key); parses Doxygen tags
# (@brief, @param, @return, ...) into structured, formatted hover output
# instead of showing the raw comment text.
Documentation:
  CommentFormat: Doxygen

---
# clangd uses x86_64 clang to parse Xtensa-targeted code; suppress the
# resulting false positives across all project source files.
# NOTE: PathMatch matches the path RELATIVE to this .clangd file's directory
# (e.g. "main/foo.cpp"), not the absolute filesystem path — no leading
# slash before the top-level directory name. Also: regex alternation tries
# branches in order, so longer extensions (cpp/hpp) must come before their
# prefixes (c/h), otherwise e.g. "foo.cpp" only matches "c" and the
# overall pattern fails on the trailing "pp".
If:
  PathMatch:
    - 'main/.*\.(cpp|hpp|c|h)'
    - 'components/.*\.(cpp|hpp|c|h)'
    - 'managed_components/.*\.(cpp|hpp|c|h)'
Diagnostics:
  Suppress:
    - unknown_typename
    - undeclared_var_use
    - undeclared_var_use_suggest
    - no_member
