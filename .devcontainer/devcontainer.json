{
  "name": "ESP-IDF · Waveshare AMOLED 2.06",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "remoteEnv": {
    "IDF_TARGET": "esp32s3"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "espressif.esp-idf-extension",
        "ms-vscode.cpptools",
        "twxs.cmake",
        "vivaxy.vscode-conventional-commits",
        "ms-vscode.cpp-devtools",
        "ms-vscode.cpptools-extension-pack",
        "Wokwi.wokwi-vscode",
        "ms-vscode.cpptools-themes",
        "xaver.clang-format",
        "llvm-vs-code-extensions.vscode-clangd",
        "ms-vscode.cmake-tools",
        "ms-azuretools.vscode-containers",
        "CppcheckSolutionsAB.cppcheck-official",
        "EditorConfig.EditorConfig",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "github.vscode-github-actions",
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens",
        "vscjava.vscode-gradle",
        "DavidAnson.vscode-markdownlint",
        "mechatroner.rainbow-csv",
        "ms-vscode.vscode-serial-monitor",
        "DotJoshJohnson.xml",
        "usernamehw.errorlens",
        "ms-vscode-remote.remote-containers",
        "aaron-bond.better-comments",
        "hediet.vscode-drawio",
        "JetBrains.kotlin-server",
        "redhat.java",
        "redhat.vscode-yaml",
        "ms-vscode.hexeditor",
        "DiemasMichiels.emulate",
        "themastercoder007.lvgl-live-preview",
        "cschlosser.doxdocgen",
        "betwo.vscode-doxygen-runner",
        "pflannery.vscode-versionlens",
        "abhiagr.logcat"
      ],
      "settings": {
        "idf.espIdfPath": "/opt/esp/idf",
        "idf.customExtraPaths": "/opt/esp/tools/bin",
        "idf.toolsPath": "/opt/esp/tools",
        "idf.adapterTargetName": "esp32s3",
        "idf.flashBaudRate": "460800",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },

  "mounts": [
    "source=/dev,target=/dev,type=bind,consistency=cached",
    "source=emsdk-cache,target=/root/.emsdk,type=volume",
    "source=vscode-server-cache,target=/root/.vscode-server,type=volume"
  ],

  "runArgs": [
    "--privileged"
    
  ],

  "postCreateCommand": "bash -c 'source /opt/esp/idf/export.sh > /dev/null 2>&1 && idf.py --version && echo ESP-IDF ready'"
}