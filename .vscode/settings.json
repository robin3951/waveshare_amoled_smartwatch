{
    "idf.currentSetup": "/opt/esp/idf",
    "idf.openOcdConfigs": [
        "board/esp32s3-builtin.cfg"
    ],
    "idf.flashType": "JTAG",
    "conventionalCommits.scopes": [
        "ui"
    ],
    "lvglPreview.displayWidth": 410,
    "lvglPreview.displayHeight": 502,
    "lvglPreview.lvglVersion": "9.4.0",
    "lvglPreview.emccOptimization": "-O1",
    "lvglPreview.autoReload": true,
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--background-index",
        "--clang-tidy",
        "--header-insertion=never",
        "--query-driver=/opt/esp/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp*-elf-gcc,/opt/esp/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp*-elf-g++,C:/Users/robin/.espressif/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp*-elf-gcc.exe,C:/Users/robin/.espressif/tools/xtensa-esp-elf/*/xtensa-esp-elf/bin/xtensa-esp*-elf-g++.exe"
    ],
    "clangd.fallbackFlags": [
        "-I${workspaceFolder}/components/ui",
        "-I${workspaceFolder}/components/ui/fonts",
        "-I${workspaceFolder}/components/SensorLib/src",
        "-I${workspaceFolder}/components/XPowersLib/src"
    ],
    "C_Cpp.intelliSenseEngine": "disabled",
    "cppcheck.cppcheckPath": "C:\\Program Files\\Cppcheck\\cppcheck.exe",
    "files.exclude": {
        "android-companion": true
    },
    "[c]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true
    },
    "[cpp]": {
        "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
        "editor.formatOnSave": true
    }
}