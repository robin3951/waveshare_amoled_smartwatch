{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Android: Deploy to Device",
            "type": "shell",
            "command": "./gradlew installDebug",
            "options": {
                "cwd": "${workspaceFolder}/android-companion"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Android: Build Debug APK",
            "type": "shell",
            "command": "./gradlew assembleDebug",
            "options": {
                "cwd": "${workspaceFolder}/android-companion"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Android: Generate KDoc",
            "type": "shell",
            "command": "./gradlew :app:dokkaHtml",
            "options": {
                "cwd": "${workspaceFolder}/android-companion"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Firmware: Generate Doxygen",
            "type": "shell",
            "command": "doxygen Doxyfile",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ]
}
